{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.gemini.google.com/*",
    "*://*.claude.ai/*",
    "*://*.chat.deepseek.com/*",
    "*://*.chatgpt.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "SmartRTL Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.gemini.google.com/*",
        "*://*.claude.ai/*",
        "*://*.chat.deepseek.com/*",
        "*://*.chatgpt.com/*",
        "http://*/*",
        "https://*/*"
      ],
      "js": ["content_script.js"],
      "css": ["content_style.css"],
      "run_at": "document_start"
    }
  ]
}
